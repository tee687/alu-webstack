#!/usr/bin/env bash
#Configure my domain zone so that the subdomain www points to my load-balancer IP (lb-01)
check_subdomain()
{
    sub=$1
    domain=$2
    result=$(dig "$sub.$domain" | awk '/ANSWER SECTION/{getline; print $4 , $5}')
    record=$(echo "$result" | awk '{print $1}')
    destination=$(echo "$result" | awk '{print $2}')
    echo "The subdomain $sub is a $record record and points to $destination"
}

domain=$1
subdomain=$2

if [ -z "$subdomain" ]
then
    for sub in www lb-01 web-01 web-02
    do
        check_subdomain $sub $domain
    done
else
   check_subdomain $subdomain $domain
fi

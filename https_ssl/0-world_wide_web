#!/usr/bin/env bash
# Displays information about subdomains for a domain

domain="$1"
subdomain="$2"

audit_subdomain() {
    local dom="$1"
    local sub="$2"
    # shellcheck disable=SC2086
    dig "${sub}.${dom}" | grep -A1 'ANSWER SECTION:' | tail -n1 | awk -v s="$sub" '{print "The subdomain " s " is a " $4 " record and points to " $5}'
}

if [ -n "$subdomain" ]; then
    audit_subdomain "$domain" "$subdomain"
else
    for sub in www lb-01 web-01 web-02; do
        audit_subdomain "$domain" "$sub"
    done
fi


#!/usr/bin/env bash
# Displays DNS subdomain information using dig and awk

domain="$1"
subdomain="$2"

audit_subdomain() {
    local s="$1"
    local d="$2"
    dig "${s}.${d}" | awk -v sub="$s" '/ANSWER SECTION:/ {
        getline
        print "The subdomain " sub " is a " $4 " record and points to " $5
    }'
}

# Ignore shellcheck case SC2086
# shellcheck disable=SC2086
if [ -n "$subdomain" ]; then
    audit_subdomain "$subdomain" "$domain"
else
    for sub in www lb-01 web-01 web-02; do
        audit_subdomain "$sub" "$domain"
    done
fi
